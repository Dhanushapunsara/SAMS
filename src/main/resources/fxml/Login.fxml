<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.sams.controller.LoginController"
           styleClass="root-pane"
           prefWidth="900" prefHeight="600">

    <VBox alignment="CENTER" spacing="20" maxWidth="360">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <Label text="SAMS" styleClass="brand-title-simple"/>
        <Label text="Student Attendance Management System" styleClass="form-subheading" wrapText="true"/>

        <Separator/>

        <VBox spacing="6">
            <Label text="Username" styleClass="field-label"/>
            <TextField fx:id="usernameField" promptText="Enter username" styleClass="text-field-custom"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Password" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" promptText="Enter password" styleClass="text-field-custom"/>
        </VBox>

        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

        <Button text="Sign In" onAction="#handleLogin"
                styleClass="btn-primary" maxWidth="Infinity"/>
    </VBox>

</StackPane>